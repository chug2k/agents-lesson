# ── LLM connection ────────────────────────────────────────────
# Point at any OpenAI-compatible endpoint.
#
# At Anduin: your internal LiteLLM proxy URL + a key from the proxy.
# Elsewhere: spin up LiteLLM locally, use Vercel AI Gateway, or
# point straight at https://api.anthropic.com/v1/ (no prompt caching).
#
# See README for the tradeoffs.

LLM_API_KEY=your-key-here
LLM_BASE_URL=https://your-proxy.example.com/v1
LLM_MODEL=claude-sonnet-4-6

# ── Sim settings ──────────────────────────────────────────────
PORT=3000
SIM_DAY_MS=8000        # how fast the fake clock ticks (8s = 1 sim day)
